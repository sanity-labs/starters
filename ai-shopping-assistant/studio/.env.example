# Copy this file to .env and fill in your values.

# Your Sanity project ID (from sanity.io/manage)
SANITY_STUDIO_PROJECT_ID=your-project-id

# Dataset name (usually "production")
SANITY_STUDIO_DATASET=production

# Anthropic API key — used at blueprint deploy time to pass the key to the function config.
#
# IMPORTANT: For the deployed function to access this key, you must ALSO add it via the CLI:
#   npx sanity functions env add agent-conversation ANTHROPIC_API_KEY your-key
#
# See https://www.sanity.io/docs/functions/function-env-vars
ANTHROPIC_API_KEY=your-anthropic-key
