# Sanity project ID
# Find at: https://sanity.io/manage or in studio/sanity.config.ts
NEXT_PUBLIC_SANITY_PROJECT_ID=

# Sanity dataset name (usually "production")
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API token with Viewer permissions (read-only)
# Used to authenticate MCP requests and fetch content
# Create at: sanity.io/manage -> Your Project -> API -> Tokens
SANITY_API_READ_TOKEN=

# Sanity API token with Editor permissions (read-write)
# Used for saving chat conversations to Sanity for classification
# Optional: conversations won't be saved if this is missing
# Create at: sanity.io/manage -> Your Project -> API -> Tokens
SANITY_API_WRITE_TOKEN=

# Agent Context slug (optional, defaults to "default")
# Must match the slug of an Agent Context document in Sanity Studio
# SANITY_CONTEXT_SLUG=default

# Agent Config slug (optional, defaults to "default")
# Must match the slug of an Agent Config document in Sanity Studio
# SANITY_AGENT_CONFIG_SLUG=default

# Anthropic API key for Claude
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=
