# Sanity project ID
# Find at: https://sanity.io/manage or in studio/sanity.config.ts
NEXT_PUBLIC_SANITY_PROJECT_ID=

# Sanity dataset name (usually "production")
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API token with Viewer permissions (read-only)
# Used to authenticate MCP requests and fetch content
# Create at: sanity.io/manage -> Your Project -> API -> Tokens
SANITY_API_READ_TOKEN=

# Sanity API token with Editor permissions (read-write)
# Used for saving chat conversations to Sanity for classification
# Optional: conversations won't be saved if this is missing
# Create at: sanity.io/manage -> Your Project -> API -> Tokens
SANITY_API_WRITE_TOKEN=

# Sanity Context MCP URL
# Gives the AI agent structured access to your content via MCP
# This URL is shown in your Agent Context document in Sanity Studio.
# If you imported the seed data, an Agent Context with slug "default" was created.
# Example: https://api.sanity.io/v2026-02-18/agent-context/<projectId>/<dataset>/default
SANITY_CONTEXT_MCP_URL=

# Anthropic API key for Claude
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=
