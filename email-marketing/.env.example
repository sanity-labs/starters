# Project vars — the Sanity CLI fills these in during `sanity init --template`.
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=

# Klaviyo API key — set after deploy via: sanity functions env add send-email KLAVIYO_API_KEY <your-key>
# Get your key at https://www.klaviyo.com/settings/account/api-keys
# KLAVIYO_API_KEY=pk_xxx
