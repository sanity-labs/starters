{
  "name": "email-marketing",
  "version": "1.0.0",
  "private": true,
  "description": "An email marketing starter with Klaviyo integration, AI-powered email generation, and campaign management. Built with Sanity Studio, Next.js 16, and Sanity Functions.",
  "keywords": [
    "AI",
    "Campaign Management",
    "Email Generation",
    "Email Marketing",
    "Klaviyo",
    "Next.js",
    "Sanity"
  ],
  "homepage": "https://github.com/sanity-labs/starters/tree/main/email-marketing#readme",
  "bugs": {
    "url": "https://github.com/sanity-labs/starters/issues"
  },
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n studio,frontend,functions -c '#f03e2f,#8b5cf6,#f5a623' 'pnpm --filter studio dev' 'pnpm --filter frontend dev' 'pnpm --filter @starter/functions build && sanity functions dev'",
    "build": "pnpm --filter @starter/functions build",
    "e2e": "pnpm --filter e2e test",
    "e2e:headed": "pnpm --filter e2e test:headed",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint --cache --cache-location node_modules/.cache/eslint/ .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "typegen": "pnpm --filter studio typegen",
    "pretypecheck": "pnpm run typegen",
    "typecheck": "pnpm -r typecheck",
    "bootstrap": "pnpm --filter studio bootstrap",
    "validate": "sanity-template-validate"
  },
  "devDependencies": {
    "@sanity/blueprints": "^0.16.0",
    "@sanity/client": "catalog:",
    "@sanity/template-validator": "^3.1.0",
    "@starter/eslint-config": "workspace:*",
    "@types/node": "^22.19.17",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "groq": "catalog:",
    "oxfmt": "^0.46.0",
    "sanity": "catalog:",
    "tsx": "^4.21.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20.19 <22 || >=22.12"
  },
  "packageManager": "pnpm@10.33.0"
}
