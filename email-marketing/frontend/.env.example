# Sanity project ID
NEXT_PUBLIC_SANITY_PROJECT_ID=

# Sanity dataset name (usually "production")
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API token with Viewer permissions (read-only)
# Create at: sanity.io/manage -> Your Project -> API -> Tokens
SANITY_API_READ_TOKEN=

# Resend API key — required for the preview route and the engagement webhook
# Create at: resend.com → API Keys
RESEND_API_KEY=

# Resend webhook signing secret (Svix). Created when you register your webhook endpoint at:
# resend.com → Webhooks → Add Webhook
RESEND_WEBHOOK_SECRET=

# Verified sending domain `from` address (must be on a domain verified in Resend dashboard)
# Example: "Brand <updates@example.com>"
RESEND_FROM_EMAIL=

# Resend test recipient — used by the 'Send test email' Studio action via on-promotion-test-send Function.
# Defaults to delivered@resend.dev (Resend's simulation address — does not actually deliver, but logs in dashboard).
# Other simulation addresses: bounced@resend.dev, complained@resend.dev. Or use your own inbox if your domain is verified.
RESEND_TEST_TO=
