# Sanity project ID
NEXT_PUBLIC_SANITY_PROJECT_ID=

# Sanity dataset name (usually "production")
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API token with Viewer permissions (read-only)
# Create at: sanity.io/manage -> Your Project -> API -> Tokens
SANITY_API_READ_TOKEN=

# Klaviyo private API key — required for the Klaviyo preview route (/api/preview/klaviyo/[id])
# Without this, the route returns the Klaviyo-format HTML without calling Klaviyo's render API
# Create at: klaviyo.com -> Settings -> API Keys
KLAVIYO_API_KEY=
