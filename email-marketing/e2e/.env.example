# Sanity project ID — must match the Studio
SANITY_STUDIO_PROJECT_ID=

# Sanity dataset to run tests against (use a dedicated test dataset, not production)
SANITY_STUDIO_DATASET=production

# Sanity API token with Editor permissions — used for direct dataset reads/writes in tests
# Create at: sanity.io/manage -> Your Project -> API -> Tokens
SANITY_E2E_SESSION_TOKEN=

# Studio dev server URL (default: http://localhost:3333)
STUDIO_URL=http://localhost:3333

# Frontend dev server URL (default: http://localhost:3000)
FRONTEND_URL=http://localhost:3000
