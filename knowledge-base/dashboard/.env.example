# App SDK app. Vars MUST be prefixed SANITY_APP_ to reach the browser bundle —
# so never put a secret here. The chat token lives in dashboard-server.
#
# Project + dataset come from your Sanity project; bootstrap maps
# SANITY_STUDIO_PROJECT_ID / SANITY_STUDIO_DATASET into the SANITY_APP_* vars below.
SANITY_APP_PROJECT_ID=
SANITY_APP_DATASET=production

# URL of the dashboard-server chat proxy.
SANITY_APP_CHAT_PROXY_URL=http://localhost:8788/api/chat

# Organization ID — required for `sanity deploy` (App SDK apps deploy to the org
# Dashboard). Find it at sanity.io/manage.
SANITY_STUDIO_ORGANIZATION_ID=
