# Copy this file to .env.local. `pnpm bootstrap` fills most of these in for you.

# Sanity project ID + dataset
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Server-side read token (Viewer role) for the private dataset.
# Never exposed to the browser. Created by bootstrap, or at:
# sanity.io/manage -> Your Project -> API -> Tokens
SANITY_READ_TOKEN_EXTERNAL=

# External Agent Context (MCP) endpoint — scoped to customer-facing content.
# Shape: https://api.sanity.io/<version>/agent-context/<projectId>/<dataset>/customer-support
# Confirm the exact URL in the Studio Agent Context panel.
SANITY_AGENT_CONTEXT_URL=

# Anthropic API key — powers the chat model (https://console.anthropic.com)
ANTHROPIC_API_KEY=
