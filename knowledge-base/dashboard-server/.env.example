# Server-side only — never bundled into a browser. `pnpm bootstrap` fills these in.
#
# This proxy targets one project/dataset: the internal MCP URL below embeds your
# SANITY_STUDIO_PROJECT_ID and SANITY_STUDIO_DATASET.

# Internal read token (Viewer role) for the private dataset.
SANITY_READ_TOKEN_INTERNAL=

# Internal Agent Context (MCP) endpoint — the "team-kb" slug, scoped to ALL types.
# Shape: https://api.sanity.io/<version>/agent-context/<projectId>/<dataset>/team-kb
SANITY_AGENT_CONTEXT_URL_INTERNAL=

# Anthropic API key — powers the chat model.
ANTHROPIC_API_KEY=

# Allowed browser origin (the App SDK dashboard) for CORS.
DASHBOARD_ORIGIN=http://localhost:3333

# Port the proxy listens on.
PORT=8788
