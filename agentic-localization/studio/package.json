{
  "name": "studio",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "sanity dev",
    "start": "sanity start",
    "build": "sanity build",
    "deploy": "sanity deploy",
    "typecheck": "tsc --noEmit",
    "schema:extract": "sanity schema extract",
    "schema:deploy": "sanity schema deploy",
    "typegen": "sanity schema extract && sanity typegen generate",
    "seed": "sanity migration run seed-locales --no-dry-run --no-confirm",
    "generate-sample-data": "sanity exec scripts/generate-sample-data.ts --with-user-token -- --out sample-data.ndjson",
    "import-sample-data": "sanity exec scripts/import-sample-data.ts --with-user-token",
    "bootstrap": "sanity exec scripts/bootstrap.ts --with-user-token"
  },
  "dependencies": {
    "@sanity/icons": "catalog:",
    "@sanity/vision": "catalog:",
    "@starter/l10n": "workspace:*",
    "react": "catalog:",
    "react-dom": "catalog:",
    "sanity": "catalog:",
    "styled-components": "catalog:"
  },
  "devDependencies": {
    "@portabletext/markdown": "^1.1.3",
    "@starter/sanity-types": "workspace:*",
    "@starter/tsconfig": "workspace:*",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "typescript": "catalog:"
  }
}
