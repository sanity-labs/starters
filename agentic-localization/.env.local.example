# Project vars — the Sanity CLI fills these in during `sanity init --template`.
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=

# Required for `sanity app deploy`
# SANITY_STUDIO_ORGANIZATION_ID=

# Production Studio URL for dashboard "Open in Studio" links
# SANITY_STUDIO_URL=

# Prefix mappings — dotenv-expand resolves these so every workspace reads from
# the same project vars above. Do not edit below this line.
SANITY_APP_PROJECT_ID=${SANITY_STUDIO_PROJECT_ID}
SANITY_APP_DATASET=${SANITY_STUDIO_DATASET}
SANITY_APP_ORGANIZATION_ID=${SANITY_STUDIO_ORGANIZATION_ID}
SANITY_APP_STUDIO_URL=${SANITY_STUDIO_URL}
SANITY_PROJECT_ID=${SANITY_STUDIO_PROJECT_ID}
SANITY_DATASET=${SANITY_STUDIO_DATASET}
