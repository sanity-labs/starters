# Angular SSR reads env from the starter root `.env.local` (see ../.env.example).
# Copy ../.env.example to ../.env.local and fill in values, or run `pnpm bootstrap`.

SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production
SANITY_API_READ_TOKEN=
SANITY_STUDIO_PREVIEW_URL=http://localhost:4200
SANITY_STUDIO_URL=http://localhost:3333
